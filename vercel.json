{
  "rewrites": [
    { "source": "/:file.css", "destination": "/68-404.html" },
    { "source": "/:file.js", "destination": "/68-404.html" }
  ],
  "routes": [
    {
      "src": "/(.*).css",
      "dest": "/68-404.html"
    },
    {
      "src": "/(.*).js",
      "dest": "/68-404.html"
    }
  ]
}
